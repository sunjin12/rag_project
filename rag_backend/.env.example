# =============================================================
# RAG Backend 환경 변수 설정 파일
# 이 파일을 복사하여 .env 파일을 만드세요: cp .env.example .env
# =============================================================

# --- 앱 서버 설정 ---
APP_HOST=0.0.0.0
APP_PORT=8000

# --- 보안 (반드시 변경하세요!) ---
# openssl rand -hex 32 명령으로 생성 가능
SECRET_KEY=change-this-to-a-random-secret-key

# --- Google OAuth 2.0 ---
GOOGLE_WEB_CLIENT_ID=your-google-web-client-id.apps.googleusercontent.com
GOOGLE_ANDROID_CLIENT_ID=your-google-android-client-id.apps.googleusercontent.com
GOOGLE_CLIENT_SECRET=your-google-client-secret

# --- PostgreSQL (대화 기록 저장) ---
POSTGRES_URL=postgresql://admin:adminpassword@localhost:5432/rag_history

# --- Redis (세션 캐시) ---
REDIS_URL=redis://localhost:6380

# --- Ollama (LLM 추론 엔진) ---
OLLAMA_URL=http://localhost:11434

# --- Qdrant (벡터 데이터베이스) ---
QDRANT_URL=http://localhost:6333

# --- CORS 허용 도메인 (콤마 구분) ---
CORS_ORIGINS=http://localhost:3000,http://localhost:8080
